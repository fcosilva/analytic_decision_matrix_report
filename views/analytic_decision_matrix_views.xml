<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_analytic_decision_matrix_wizard_form" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.wizard.form</field>
        <field name="model">analytic.decision.matrix.wizard</field>
        <field name="arch" type="xml">
            <form string="Matriz Decision Analitica">
                <header>
                    <button name="action_compute" type="object" string="Generar Matriz" class="btn-primary" />
                    <button name="action_print_pdf" type="object" string="Imprimir PDF" class="btn-secondary" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="company_id" />
                            <field name="date_from" />
                            <field name="date_to" />
                            <field name="drilldown_document_view" />
                        </group>
                    </group>
                    <separator string="Proyectos (Cuentas Analiticas)" />
                    <field name="line_ids" nolabel="1" readonly="1" options="{'no_open': True}">
                        <tree create="0" delete="0" edit="0" decoration-bf="is_total">
                            <field name="project_label" />
                            <button
                                name="action_open_documents"
                                type="object"
                                icon="fa-external-link"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="ingreso" />
                            <button
                                name="action_open_ingreso_documents"
                                type="object"
                                icon="fa-external-link"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="cxc" />
                            <button
                                name="action_open_cxc_documents"
                                type="object"
                                icon="fa-external-link"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="reasignacion_in" />
                            <button
                                name="action_open_reasignacion_in_documents"
                                type="object"
                                icon="fa-external-link"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="egresos" />
                            <button
                                name="action_open_egresos_documents"
                                type="object"
                                icon="fa-external-link"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="cxp" />
                            <button
                                name="action_open_cxp_documents"
                                type="object"
                                icon="fa-external-link"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="reasignacion_out" />
                            <button
                                name="action_open_reasignacion_out_documents"
                                type="object"
                                icon="fa-external-link"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="saldo_devengado" />
                            <field name="saldo_efectivo" />
                            <field name="currency_id" column_invisible="True" />
                            <field name="is_total" column_invisible="True" />
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_analytic_decision_matrix_wizard_tree" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.wizard.tree</field>
        <field name="model">analytic.decision.matrix.wizard</field>
        <field name="arch" type="xml">
            <tree string="Matrices de Decision Analitica">
                <field name="name" />
                <field name="company_id" />
                <field name="date_from" />
                <field name="date_to" />
                <field name="include_reversed" />
                <field name="drilldown_document_view" />
                <field name="analytic_plan_id" />
                <field name="reasignacion_journal_code" />
                <field name="last_compute_at" />
                <field name="create_date" string="Creado" />
            </tree>
        </field>
    </record>

    <record id="view_analytic_decision_matrix_wizard_form_filters_right" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.wizard.form.filters.right</field>
        <field name="model">analytic.decision.matrix.wizard</field>
        <field name="inherit_id" ref="analytic_decision_matrix_report.view_analytic_decision_matrix_wizard_form" />
        <field name="priority" eval="100" />
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group/group[1]" position="after">
                <group>
                    <field name="analytic_plan_id" />
                    <field name="analytic_account_ids" widget="many2many_tags" options="{'no_create': True}" />
                    <field name="include_reversed" />
                    <field name="reasignacion_journal_code" />
                    <field name="last_compute_at" readonly="1" />
                </group>
            </xpath>
        </field>
    </record>

    <record id="action_analytic_decision_matrix_wizard" model="ir.actions.act_window">
        <field name="name">Matriz Decision Analitica</field>
        <field name="res_model">analytic.decision.matrix.wizard</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
    </record>

    <record id="view_analytic_decision_matrix_open_move_tree" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.open.move.tree</field>
        <field name="model">analytic.decision.matrix.open.move</field>
        <field name="arch" type="xml">
            <tree string="Detalle Ctas x Cob/Pag" create="0" edit="0" delete="0" decoration-bf="is_total">
                <field name="analytic_account_id" />
                <field name="target_key" />
                <field name="move_label" />
                <field name="move_id" column_invisible="True" />
                <field name="partner_id" />
                <field name="invoice_date" />
                <field name="date" />
                <field name="amount_residual_total" />
                <field name="analytic_ratio" />
                <field name="amount_residual_analytic" />
                <field name="is_total" column_invisible="True" />
            </tree>
        </field>
    </record>

    <record id="view_analytic_decision_matrix_open_move_form" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.open.move.form</field>
        <field name="model">analytic.decision.matrix.open.move</field>
        <field name="arch" type="xml">
            <form string="Detalle Ctas x Cob/Pag" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="analytic_account_id" />
                            <field name="target_key" />
                            <field name="move_label" />
                            <field name="move_id" />
                            <field name="partner_id" />
                        </group>
                        <group>
                            <field name="invoice_date" />
                            <field name="date" />
                            <field name="amount_residual_total" />
                            <field name="analytic_ratio" />
                            <field name="amount_residual_analytic" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem
        id="menu_analytic_decision_matrix_wizard"
        name="Matriz Decision Analitica"
        parent="account.menu_finance_reports"
        action="action_analytic_decision_matrix_wizard"
        sequence="95"
    />

</odoo>
