<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_analytic_decision_matrix_wizard_form" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.wizard.form</field>
        <field name="model">analytic.decision.matrix.wizard</field>
        <field name="arch" type="xml">
            <form string="Matriz Decision Analitica">
                <header>
                    <button name="action_compute" type="object" string="Generar Matriz" class="btn-primary" />
                    <button name="action_print_pdf" type="object" string="Imprimir PDF" class="btn-secondary" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="company_id" />
                            <field name="date_from" />
                            <field name="date_to" />
                            <field name="drilldown_document_view" />
                        </group>
                    </group>
                    <separator string="Proyectos (Cuentas Analiticas)" />
                    <field name="line_ids" nolabel="1" readonly="1">
                        <tree create="0" delete="0" edit="0" decoration-bf="is_total">
                            <field name="project_label" />
                            <field name="ingreso" sum="Total ingreso" />
                            <button
                                name="action_open_ingreso_documents"
                                type="object"
                                icon="fa-external-link"
                                title="Abrir detalle de ingreso"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="cxc" sum="Total CxC" />
                            <button
                                name="action_open_cxc_documents"
                                type="object"
                                icon="fa-external-link"
                                title="Abrir detalle de cuentas por cobrar"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="reasignacion_in" sum="Total reasignación (+)" />
                            <button
                                name="action_open_reasignacion_in_documents"
                                type="object"
                                icon="fa-external-link"
                                title="Abrir detalle de reasignacion positiva"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="egresos" sum="Total egresos" />
                            <button
                                name="action_open_egresos_documents"
                                type="object"
                                icon="fa-external-link"
                                title="Abrir detalle de egresos"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="cxp" sum="Total CxP" />
                            <button
                                name="action_open_cxp_documents"
                                type="object"
                                icon="fa-external-link"
                                title="Abrir detalle de cuentas por pagar"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="reasignacion_out" sum="Total reasignación (-)" />
                            <button
                                name="action_open_reasignacion_out_documents"
                                type="object"
                                icon="fa-external-link"
                                title="Abrir detalle de reasignacion negativa"
                                class="btn-link"
                                invisible="is_total"
                            />
                            <field name="saldo_devengado" sum="Total saldo devengado" />
                            <field name="saldo_efectivo" sum="Total saldo efectivo" />
                            <field name="currency_id" column_invisible="True" />
                            <field name="is_total" column_invisible="True" />
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_analytic_decision_matrix_wizard_line_form" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.wizard.line.form</field>
        <field name="model">analytic.decision.matrix.wizard.line</field>
        <field name="arch" type="xml">
            <form string="Detalle de Proyecto" create="0" edit="0" delete="0">
                <sheet>
                    <group>
                        <group>
                            <field name="project_label" readonly="1" />
                            <field name="wizard_id" readonly="1" />
                        </group>
                        <group>
                            <field name="currency_id" invisible="1" />
                        </group>
                    </group>
                    <separator string="Resumen" />
                    <group>
                        <group>
                            <field name="ingreso" readonly="1" />
                            <field name="cxc" readonly="1" />
                            <field name="reasignacion_in" readonly="1" />
                            <field name="saldo_devengado" readonly="1" />
                        </group>
                        <group>
                            <field name="egresos" readonly="1" />
                            <field name="cxp" readonly="1" />
                            <field name="reasignacion_out" readonly="1" />
                            <field name="saldo_efectivo" readonly="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Ingresos">
                            <field name="modal_ingreso_detail_ids" readonly="1">
                                <tree create="0" edit="0" delete="0" import="0">
                                    <field name="move_id" string="Documento" />
                                    <button name="action_open_business_doc_current" type="object" icon="fa-external-link-square" title="Abrir en pantalla completa" class="btn-link" />
                                    <field name="partner_id" string="Contacto" />
                                    <field name="invoice_date" string="Fecha Factura" />
                                    <field name="invoice_date_due" string="Fecha Vencimiento" />
                                    <field name="date" string="Fecha Contable" />
                                    <field name="amount_analytic" sum="Total ingresos" />
                                    <field name="currency_id" column_invisible="True" />
                                </tree>
                            </field>
                        </page>
                        <page string="Egresos">
                            <field name="modal_egresos_detail_ids" readonly="1">
                                <tree create="0" edit="0" delete="0" import="0">
                                    <field name="move_id" string="Documento" />
                                    <button name="action_open_business_doc_current" type="object" icon="fa-external-link-square" title="Abrir en pantalla completa" class="btn-link" />
                                    <field name="partner_id" string="Contacto" />
                                    <field name="invoice_date" string="Fecha Factura" />
                                    <field name="invoice_date_due" string="Fecha Vencimiento" />
                                    <field name="date" string="Fecha Contable" />
                                    <field name="amount_analytic" sum="Total egresos" />
                                    <field name="currency_id" column_invisible="True" />
                                </tree>
                            </field>
                        </page>
                        <page string="Ctas x Cob">
                            <field name="modal_cxc_detail_ids" readonly="1">
                                <tree create="0" edit="0" delete="0" import="0">
                                    <field name="move_id" string="Documento" />
                                    <button name="action_open_business_doc_current" type="object" icon="fa-external-link-square" title="Abrir en pantalla completa" class="btn-link" />
                                    <field name="partner_id" string="Contacto" />
                                    <field name="invoice_date" string="Fecha Factura" />
                                    <field name="invoice_date_due" string="Fecha Vencimiento" />
                                    <field name="date" string="Fecha Contable" />
                                    <field name="amount_analytic" sum="Total CxC" />
                                    <field name="currency_id" column_invisible="True" />
                                </tree>
                            </field>
                        </page>
                        <page string="Ctas x Pag">
                            <field name="modal_cxp_detail_ids" readonly="1">
                                <tree create="0" edit="0" delete="0" import="0">
                                    <field name="move_id" string="Documento" />
                                    <button name="action_open_business_doc_current" type="object" icon="fa-external-link-square" title="Abrir en pantalla completa" class="btn-link" />
                                    <field name="partner_id" string="Contacto" />
                                    <field name="invoice_date" string="Fecha Factura" />
                                    <field name="invoice_date_due" string="Fecha Vencimiento" />
                                    <field name="date" string="Fecha Contable" />
                                    <field name="amount_analytic" sum="Total CxP" />
                                    <field name="currency_id" column_invisible="True" />
                                </tree>
                            </field>
                        </page>
                        <page string="Reasignación (+)">
                            <field name="modal_reasignacion_in_detail_ids" readonly="1">
                                <tree create="0" edit="0" delete="0" import="0">
                                    <field name="move_id" string="Documento" />
                                    <button name="action_open_business_doc_current" type="object" icon="fa-external-link-square" title="Abrir en pantalla completa" class="btn-link" />
                                    <field name="partner_id" string="Contacto" />
                                    <field name="invoice_date" string="Fecha Factura" />
                                    <field name="invoice_date_due" string="Fecha Vencimiento" />
                                    <field name="date" string="Fecha Contable" />
                                    <field name="amount_analytic" sum="Total reasignación (+)" />
                                    <field name="currency_id" column_invisible="True" />
                                </tree>
                            </field>
                        </page>
                        <page string="Reasignación (-)">
                            <field name="modal_reasignacion_out_detail_ids" readonly="1">
                                <tree create="0" edit="0" delete="0" import="0">
                                    <field name="move_id" string="Documento" />
                                    <button name="action_open_business_doc_current" type="object" icon="fa-external-link-square" title="Abrir en pantalla completa" class="btn-link" />
                                    <field name="partner_id" string="Contacto" />
                                    <field name="invoice_date" string="Fecha Factura" />
                                    <field name="invoice_date_due" string="Fecha Vencimiento" />
                                    <field name="date" string="Fecha Contable" />
                                    <field name="amount_analytic" sum="Total reasignación (-)" />
                                    <field name="currency_id" column_invisible="True" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_analytic_decision_matrix_wizard_tree" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.wizard.tree</field>
        <field name="model">analytic.decision.matrix.wizard</field>
        <field name="arch" type="xml">
            <tree string="Matrices de Decision Analitica">
                <field name="name" />
                <field name="company_id" />
                <field name="date_from" />
                <field name="date_to" />
                <field name="include_reversed" />
                <field name="drilldown_document_view" />
                <field name="analytic_plan_id" />
                <field name="reasignacion_journal_code" />
                <field name="last_compute_at" />
                <field name="create_date" string="Creado" />
            </tree>
        </field>
    </record>

    <record id="view_analytic_decision_matrix_wizard_form_filters_right" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.wizard.form.filters.right</field>
        <field name="model">analytic.decision.matrix.wizard</field>
        <field name="inherit_id" ref="analytic_decision_matrix_report.view_analytic_decision_matrix_wizard_form" />
        <field name="priority" eval="100" />
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group/group[1]" position="after">
                <group>
                    <field name="analytic_plan_id" />
                    <field name="analytic_account_ids" widget="many2many_tags" options="{'no_create': True}" />
                    <field name="include_reversed" />
                    <field name="reasignacion_journal_code" />
                    <field name="last_compute_at" readonly="1" />
                </group>
            </xpath>
        </field>
    </record>

    <record id="action_analytic_decision_matrix_wizard" model="ir.actions.act_window">
        <field name="name">Matriz Decision Analitica</field>
        <field name="res_model">analytic.decision.matrix.wizard</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
    </record>

    <record id="view_analytic_decision_matrix_open_move_tree" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.open.move.tree</field>
        <field name="model">analytic.decision.matrix.open.move</field>
        <field name="arch" type="xml">
            <tree string="Detalle Ctas x Cob/Pag" create="0" edit="0" delete="0" import="0" decoration-bf="is_total">
                <field name="target_key" invisible="is_total" />
                <field name="move_id" string="Documento" />
                <button
                    name="action_open_business_doc_current"
                    type="object"
                    icon="fa-external-link-square"
                    title="Abrir en pantalla completa"
                    class="btn-link"
                    invisible="is_total"
                />
                <field name="partner_id" string="Contacto" invisible="is_total" />
                <field name="invoice_date" string="Fecha Factura" invisible="is_total" />
                <field name="invoice_date_due" string="Fecha Vencimiento" invisible="is_total" />
                <field name="days_overdue" invisible="is_total" />
                <field name="date" string="Fecha Contable" invisible="is_total" />
                <field name="amount_residual_total" sum="Total residual documento" />
                <field name="analytic_ratio" invisible="is_total" />
                <field name="amount_residual_analytic" sum="Total residual analitico" />
                <field name="currency_id" column_invisible="True" />
                <field name="is_total" column_invisible="True" />
            </tree>
        </field>
    </record>

    <record id="view_analytic_decision_matrix_open_move_form" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.open.move.form</field>
        <field name="model">analytic.decision.matrix.open.move</field>
        <field name="arch" type="xml">
            <form string="Detalle Ctas x Cob/Pag" create="0" edit="0" delete="0">
                <sheet>
                    <field name="is_total" invisible="1" />
                    <group>
                        <group>
                            <field name="target_key" invisible="is_total" />
                            <field name="move_label" invisible="not is_total" />
                            <field name="move_id" invisible="is_total" />
                            <field name="partner_id" invisible="is_total" />
                        </group>
                        <group>
                            <field name="invoice_date" invisible="is_total" />
                            <field name="invoice_date_due" invisible="is_total" />
                            <field name="days_overdue" invisible="is_total" />
                            <field name="date" invisible="is_total" />
                            <field name="amount_residual_total" />
                            <field name="analytic_ratio" invisible="is_total" />
                            <field name="amount_residual_analytic" />
                            <field name="currency_id" invisible="1" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_analytic_decision_matrix_open_move_search" model="ir.ui.view">
        <field name="name">analytic.decision.matrix.open.move.search</field>
        <field name="model">analytic.decision.matrix.open.move</field>
        <field name="arch" type="xml">
            <search string="Buscar detalle Ctas x Cob/Pag">
                <field name="move_id" />
                <field name="partner_id" />
                <field name="target_key" />
                <field name="invoice_date" />
                <field name="invoice_date_due" />
                <filter name="filter_cxc" string="Ctas x Cob" domain="[('target_key', '=', 'cxc')]" />
                <filter name="filter_cxp" string="Ctas x Pag" domain="[('target_key', '=', 'cxp')]" />
                <filter name="filter_vencidos" string="Vencidos" domain="[('is_overdue', '=', True)]" />
                <filter name="filter_no_vencidos" string="No vencidos" domain="[('is_overdue', '=', False)]" />
                <group expand="0" string="Agrupar por">
                    <filter name="group_partner" string="Contacto" context="{'group_by': 'partner_id'}" />
                    <filter name="group_target" string="Tipo" context="{'group_by': 'target_key'}" />
                    <filter name="group_due_date" string="Vencimiento" context="{'group_by': 'invoice_date_due'}" />
                    <filter name="group_document" string="Documento" context="{'group_by': 'move_id'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_analytic_decision_matrix_open_move" model="ir.actions.act_window">
