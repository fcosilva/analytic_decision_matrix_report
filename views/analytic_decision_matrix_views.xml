    <record id="view_analytic_reassignment_wizard_form" model="ir.ui.view">
        <field name="name">analytic.reassignment.wizard.form</field>
        <field name="model">analytic.reassignment.wizard</field>
        <field name="arch" type="xml">
            <form string="Asistente de Reasignación Analítica">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,preview,done" />
                    <button
                        name="action_preview"
                        type="object"
                        string="Previsualizar"
                        class="btn-secondary"
                        invisible="state == 'done'"
                    />
                    <button
                        name="action_confirm"
                        type="object"
                        string="Confirmar y Contabilizar"
                        class="btn-primary"
                        invisible="state == 'done'"
                    />
                </header>
                <sheet>
                    <group string="Información General" col="2">
                        <group>
                            <field name="name" readonly="1" />
                            <field name="company_id" readonly="state == 'done'" />
                            <field name="date" readonly="state == 'done'" />
                            <field name="move_id" readonly="1" />
                        </group>
                        <group>
                            <field name="journal_id" readonly="state == 'done'" />
                            <field name="bridge_account_id" readonly="state == 'done'" />
                            <field name="amount" readonly="state == 'done'" />
                            <field name="support_ref" readonly="state == 'done'" />
                            <field name="currency_id" invisible="1" />
                        </group>
                    </group>
                    <group string="Detalle de Reasignación" col="2">
                        <group>
                            <field name="analytic_origin_id" readonly="state == 'done'" />
                            <field name="reason" readonly="state == 'done'" />
                        </group>
                        <group>
                            <field name="analytic_destination_id" readonly="state == 'done'" />
                        </group>
                    </group>
                    <group invisible="not warning_message">
                        <field name="warning_message" readonly="1" />
                    </group>
                    <separator string="Previsualización de Impacto" invisible="state == 'draft'" />
                    <div invisible="state == 'draft'" class="oe_clear">
                        <table class="table table-sm table-hover o_list_table">
                            <thead>
                                <tr>
                                    <th>Proyecto</th>
                                    <th>Saldo Devengado Antes</th>
                                    <th>Saldo Devengado Después</th>
                                    <th>Saldo Efectivo Antes</th>
                                    <th>Saldo Efectivo Después</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
